APP_NAME="SoukJannah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Prod : https://soukjannah.com (ou ton domaine final)
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce_halal
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="support@soukjannah.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email affiché sur Contact / légal (défaut si absent : support@soukjannah.com).
SUPPORT_CONTACT_EMAIL="support@soukjannah.com"

# Boutique vide : page « ouverture prochaine » (auto si aucun produit actif ; true = forcer)
SHOP_CATALOG_COMING_SOON=false

RESEND_API_KEY=
ADMIN_EMAIL=

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

CRON_SECRET_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local : http://localhost/auth/google/callback — Prod : https://soukjannah.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback
